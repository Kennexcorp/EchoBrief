# Copy to .env and adjust as needed. All values shown are the defaults.

# Ollama endpoint. Under docker compose: http://ollama:11434
# Docker app + host-installed Ollama: http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434

# Any locally pulled chat model (ollama pull llama3.1:8b)
OLLAMA_MODEL=llama3.1:8b

# Whisper model size: base (low-RAM machines) | small (default) | medium+ (GPU)
WHISPER_MODEL_SIZE=small

# int8 on CPU (default), float16 on GPU
WHISPER_COMPUTE_TYPE=int8

# --- Optional: spoken audio output via ElevenLabs (the only feature that leaves the machine) ---
# Leave ELEVENLABS_API_KEY unset to keep EchoBrief 100% local. Set it (free tier at
# https://elevenlabs.io) to enable `echobrief call.mp3 --speak brief.mp3`.
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL=eleven_multilingual_v2
